# ============================================================================
# Home Services AI Voice Agent — configuration template
# Copy to .env and fill in your values. Every value is per-tenant.
# ============================================================================

# --- Multi-tenancy ---
BUSINESS_ID=default-business
BUSINESS_NAME=Acme Home Services

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Public HTTPS URL Twilio can reach (ngrok in dev, your domain in prod)
PUBLIC_BASE_URL=https://your-domain.example.com
LOG_LEVEL=INFO

# --- Twilio (Programmable Voice + Media Streams + SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567
# Business owner: receives emergency SMS + lead summaries
OWNER_PHONE_NUMBER=+15557654321
# Set false ONLY for local dev without real Twilio signatures
VALIDATE_TWILIO_SIGNATURE=true
# Per-deployment call recording toggle
ENABLE_RECORDING=false

# --- Deepgram streaming STT (free tier: 100 hours/month) ---
DEEPGRAM_API_KEY=your_deepgram_key
DEEPGRAM_MODEL=nova-2

# --- ElevenLabs Flash TTS ---
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_flash_v2_5
# Set false to fall back to Twilio's built-in <Say> TTS ($0)
USE_ELEVENLABS_TTS=true

# --- LLM via LiteLLM (the ONLY LLM access layer) ---
GROQ_API_KEY=gsk_your_groq_key
MISTRAL_API_KEY=your_mistral_key
LLM_PRIMARY=groq/llama-3.3-70b-versatile
LLM_FALLBACK=mistral/mistral-small-latest
LLM_TERTIARY=mistral/ministral-3b-latest
LLM_TIMEOUT_SECONDS=3.0
# Groq free tier for llama-3.3-70b-versatile: 30 req/min, 1000 req/day
GROQ_DAILY_REQUEST_CAP=1000
GROQ_WARN_THRESHOLD=0.8

# --- Supabase (free tier) ---
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_service_role_key

# --- FSM integration: jobber | housecallpro | generic ---
FSM_PROVIDER=generic
JOBBER_API_TOKEN=
JOBBER_GRAPHQL_URL=https://api.getjobber.com/api/graphql
HOUSECALLPRO_API_KEY=
HOUSECALLPRO_BASE_URL=https://api.housecallpro.com

# --- Service area (comma-separated ZIP codes) ---
SERVICE_AREA_ZIP_CODES=78701,78702,78703,78704,78705
# Optional referral offered when out of area (leave blank to skip)
REFERRAL_BUSINESS_NAME=
REFERRAL_BUSINESS_PHONE=

# --- Conversation timeouts ---
SILENCE_PROMPT_SECONDS=10.0
SILENCE_HANGUP_SECONDS=7.0

# --- Duplicate detection window (minutes) ---
DUPLICATE_WINDOW_MINUTES=60
